AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SoftKatta Central Licensing (prefer /install wizard on first setup)
SOFTKATTA_LICENSING_ENABLED=true
SOFTKATTA_COMPANY_API_URL=https://api.softkatta.in/api/v1/company
SOFTKATTA_PUBLIC_API_KEY=
