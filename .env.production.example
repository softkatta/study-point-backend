APP_NAME=StudyPoint
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://study-api.softkatta.in

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=study_point
DB_USERNAME=study_point_user
DB_PASSWORD=replace-with-strong-password

# Set unique production admin bootstrap only for first seed run
SEED_SUPER_ADMIN_EMAIL=admin@your-domain.com
SEED_SUPER_ADMIN_NAME=Super Admin
SEED_SUPER_ADMIN_PASSWORD=replace-with-strong-password

SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.your-domain.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-user
MAIL_PASSWORD=your-smtp-password
MAIL_FROM_ADDRESS=no-reply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=https://softkatta.in
CORS_ALLOWED_ORIGINS=https://softkatta.in,https://www.softkatta.in
SANCTUM_STATEFUL_DOMAINS=softkatta.in,www.softkatta.in,localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
